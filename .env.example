# OBRIGATORIO — gere com: python -c "import secrets; print(secrets.token_hex(50))"
DJANGO_SECRET_KEY=troque-esta-chave-antes-de-subir

DJANGO_DEBUG=False

# Hosts permitidos (separados por virgula, sem espacos)
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,192.168.17.89

# OBRIGATORIO em producao — liste todos os dominios/IPs que fazem POST ao sistema
# Sem isso, formularios podem falhar com CSRF error atras de proxy reverso (nginx)
# Exemplo: https://meudominio.com.br,http://192.168.1.100:8010
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:8010,http://127.0.0.1:8010,http://192.168.17.89:8010

DATABASE_ENGINE=mysql
DATABASE_NAME=hub_agentes
DATABASE_USER=hub_agentes
DATABASE_PASSWORD=troque-a-senha-do-banco
DATABASE_HOST=db
DATABASE_PORT=3306
MYSQL_ROOT_PASSWORD=troque-a-senha-root-do-mysql

# Chave Fernet para criptografia de campos sensiveis (api_key, credentials_json).
# Gere com: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FIELD_ENCRYPTION_KEY=gere-uma-chave-fernet-aqui

# Superusuario criado automaticamente na primeira subida do container (se nao existir nenhum admin).
# Altere apos o primeiro login.
DJANGO_ADMIN_USER=eliasneto
DJANGO_ADMIN_PASSWORD=eliasneto
